{
  "name": "@bndynet/icharts",
  "version": "6.0.0",
  "description": "A simplified ECharts wrapper providing an <i-chart> web component and createChart() API",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "cd site && npm i && npm run dev",
    "build": "tsup && cd site && npm i && npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@bndynet/color-hub": "^0.1.0",
    "echarts": "^6.0.0",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "author": "Bendy Zhang",
  "repository": {
    "type": "git",
    "url": "https://github.com/bndynet/icharts.git"
  },
  "keywords": [
    "echarts",
    "chart",
    "web-component",
    "lit",
    "visualization"
  ]
}
